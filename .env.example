# Zinnia API — server-side only (same usage as Swagger/Postman: OAuth + Bearer on each call).
# Base URL must include API version path, e.g. dep-platform-admin-console/v1
ZINNIA_BASE_URL=https://dev.api.zinnia.io/dep-platform-admin-console/v1
# OAuth client-credentials token endpoint
ZINNIA_TOKEN_URL=https://login.dev.zinnia.com/oauth/token
# Token request body "audience" (defaults to https://dev.api.zinnia.io if unset)
# ZINNIA_TOKEN_AUDIENCE=https://dev.api.zinnia.io
ZINNIA_CLIENT_ID=
ZINNIA_CLIENT_SECRET=

# OpenAI (server-side intent + extraction — never expose to the browser)
OPENAI_API_KEY=

# Optional legacy alias for AI key
# AI_API_KEY=

# Optional: chat completions model for intent/extraction (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
