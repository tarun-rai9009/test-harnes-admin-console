# Zinnia API — server-side only (OAuth + Bearer on each call).
ZINNIA_BASE_URL=https://your-api-host/your-api-prefix/v1
ZINNIA_TOKEN_URL=https://your-login-host/oauth/token
# ZINNIA_TOKEN_AUDIENCE=https://dev.api.zinnia.io
ZINNIA_CLIENT_ID=
ZINNIA_CLIENT_SECRET=

# Optional: print [llm] lines when calling OpenAI/Azure (default: only in next dev)
# LLM_DEBUG=1

# --- Option A: OpenAI.com ---

# Optional legacy alias:
# AI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Option B: Azure OpenAI (if AZURE_OPENAI_ENDPOINT is set, requests go to Azure) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
OPENAI_API_KEY=  
# Optional: pin deployment (otherwise the app lists deployments and picks one, or guesses gpt-4o-mini):
# AZURE_OPENAI_DEPLOYMENT=my-gpt-deployment
# OPENAI_MODEL=my-gpt-deployment
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_DEPLOYMENTS_LIST_API_VERSION=2023-05-15
